server:
  port: 8080
  servlet:
    context-path: /api

spring:
  application:
    name: erp-server
  flyway:
    enabled: true
    baseline-on-migrate: true
    validate-on-migrate: false
    out-of-order: true
  datasource:
    url: jdbc:postgresql://localhost:5432/neko_erp
    username: neko
    password: neko
    driver-class-name: org.postgresql.Driver
  data:
    redis:
      host: localhost
      port: 6379
      database: 0
  rabbitmq:
    host: localhost
    port: 5672
    username: guest
    password: guest

mybatis-plus:
  configuration:
    map-underscore-to-camel-case: true

jwt:
  secret: neko-erp-preview-secret-change-this
  expiration: 86400000

minio:
  endpoint: http://localhost:9000
  access-key: minioadmin
  secret-key: minioadmin
  bucket: erp-files
