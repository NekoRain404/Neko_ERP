<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.server.modules.stock.mapper.StockInventoryMapper">
    <select id="selectPageByQuery" resultType="com.erp.server.modules.stock.entity.StockInventory">
        SELECT id,
        name,
        date,
        state,
        location_ids,
        company_id FROM stock_inventory
        <where>
            <if test="query.date != null">
                AND date::date = #{query.date}::date
            </if>
            <if test="query.state != null and query.state != ''">
                AND state = #{query.state}
            </if>
            <if test="query.companyId != null">
                AND company_id = #{query.companyId}
            </if>
            <if test="query.keyword != null and query.keyword != ''">
                AND (
                    name ILIKE CONCAT('%', #{query.keyword}, '%')
                    OR location_ids ILIKE CONCAT('%', #{query.keyword}, '%')
                )
            </if>
        </where>
        ORDER BY id DESC
    </select>
</mapper>
